{
  "name": "mneme",
  "version": "0.2.0",
  "description": "Unified Context Management Platform for AI Agents",
  "keywords": [
    "ai",
    "context",
    "memory",
    "agents",
    "llm",
    "rag",
    "retrieval"
  ],
  "homepage": "https://github.com/mneme/mneme#readme",
  "bugs": {
    "url": "https://github.com/mneme/mneme/issues"
  },
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mneme/mneme.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mneme": "dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "benchmark:run": "vitest run test/benchmarks --reporter=json --outputFile=benchmark-results.json",
    "benchmark:compare": "node scripts/compare-benchmarks.js",
    "fixtures:generate": "tsx scripts/generate-fixtures.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^5.0.0",
    "express": "^5.0.0",
    "hono": "^4.0.0",
    "pdf-parse": "^2.4.5",
    "sqlite-vec": "^0.1.7",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
